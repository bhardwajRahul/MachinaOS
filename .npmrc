# pnpm settings (ignored by npm)
#
# auto-install-peers: pnpm installs missing peer deps automatically (matches
# npm 7+ behavior). Removes manual peer-dep management for contributors.
auto-install-peers=true

# strict-peer-dependencies: true catches mismatched peer deps at install time.
# Allowed exceptions are in package.json pnpm.peerDependencyRules.
strict-peer-dependencies=true

# shamefully-hoist: keep false (pnpm default). Strict node_modules layout
# catches phantom deps. If a specific library breaks (e.g., some Babel
# plugins), prefer `public-hoist-pattern[]=<lib>` over enabling shameful hoist.
shamefully-hoist=false

# node-linker: isolated is pnpm's default and the whole point of using it
# (content-addressable store + symlinks). Declared explicitly to avoid
# surprise if a future pnpm version changes defaults.
node-linker=isolated
