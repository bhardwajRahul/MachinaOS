# WhatsApp RPC Dockerfile
# Uses the npm package edgymeow with pre-built binaries

FROM node:20-alpine

WORKDIR /app

# Install the edgymeow package
RUN npm init -y && npm install edgymeow

# Create data directory for SQLite and QR codes
RUN mkdir -p /app/data

# Set environment variables
ENV NODE_ENV=production
ENV TZ=UTC
ENV PORT=9400

# Expose the RPC port (configurable via PORT env var)
EXPOSE ${PORT}

# Run the RPC server
CMD ["npx", "edgymeow", "api", "--foreground"]
